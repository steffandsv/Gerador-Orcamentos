generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                  Int         @id @default(autoincrement())
  nome                String      @db.VarChar(255)
  documento           String?     @db.VarChar(50)
  endereco            String?     @db.Text
  telefone            String?     @db.VarChar(50)
  email               String?     @db.VarChar(100)
  detalhes_adicionais String?     @db.Text
  smtp_host           String?     @db.VarChar(255)
  smtp_port           String?     @db.VarChar(10)
  smtp_user           String?     @db.VarChar(255)
  smtp_pass           String?     @db.VarChar(255)
  smtp_secure         String?     @db.VarChar(20)

  // Relações com orçamentos onde esta empresa foi referenciada
  orcamentos1 Orcamento[] @relation("Empresa1")
  orcamentos2 Orcamento[] @relation("Empresa2")
  orcamentos3 Orcamento[] @relation("Empresa3")

  @@map("empresas")
}

model Orcamento {
  id               Int       @id @default(autoincrement())
  titulo           String    @db.VarChar(255)
  data_criacao     DateTime? @default(now()) @db.DateTime(0)
  
  empresa1_id      Int
  empresa2_id      Int
  empresa3_id      Int
  
  variacao_maxima  Decimal   @db.Decimal(5, 2)
  template1_id     Int?      @default(1)
  template2_id     Int?      @default(2)
  template3_id     Int?      @default(3)
  
  solicitante_nome String?   @db.VarChar(255)
  solicitante_cnpj String?   @db.VarChar(20)

  empresa1 Empresa @relation("Empresa1", fields: [empresa1_id], references: [id])
  empresa2 Empresa @relation("Empresa2", fields: [empresa2_id], references: [id])
  empresa3 Empresa @relation("Empresa3", fields: [empresa3_id], references: [id])

  itens ItemOrcamento[]

  @@map("orcamentos")
}

model ItemOrcamento {
  id             Int       @id @default(autoincrement())
  orcamento_id   Int
  descricao      String    @db.VarChar(255)
  unidade        String?   @default("UN") @db.VarChar(20)
  quantidade     Decimal   @db.Decimal(10, 2)
  preco_unitario Decimal   @db.Decimal(10, 2)

  orcamento Orcamento @relation(fields: [orcamento_id], references: [id], onDelete: Cascade)

  @@map("itens_orcamento")
}
