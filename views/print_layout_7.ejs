<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Orçamento - <%= company.nome %></title>
    <style>
        body { font-family: 'Verdana', sans-serif; padding: 30px; background: #eef2f3; }
        @page { size: A4; margin: 1cm; }
        .page-container { background: #fff; padding: 40px; border: 1px solid #ccc; box-shadow: 0 0 10px rgba(0,0,0,0.1); min-height: 900px; }
        
        .header { display: flex; justify-content: space-between; margin-bottom: 40px; }
        .logo { background: #34495e; color: #fff; padding: 20px; font-weight: bold; font-size: 24px; }
        .details { text-align: right; font-size: 12px; line-height: 1.5; }
        
        .title-bar { background: #34495e; color: #fff; padding: 10px 20px; font-size: 18px; margin-bottom: 20px; border-radius: 4px; }
        
        table { width: 100%; border-spacing: 0; margin-bottom: 30px; border: 1px solid #ddd; }
        th { background: #f2f2f2; padding: 12px; text-align: left; border-bottom: 1px solid #ddd; font-size: 12px; color: #555; }
        td { padding: 12px; border-bottom: 1px solid #ddd; font-size: 13px; }
        tr:last-child td { border-bottom: none; }
        
        .summary { float: right; width: 300px; border: 1px solid #ddd; padding: 15px; background: #f9f9f9; }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .summary-total { font-weight: bold; font-size: 16px; color: #34495e; border-top: 1px solid #ccc; padding-top: 10px; }
        
        .notes { margin-top: 20px; border-left: 4px solid #34495e; padding-left: 15px; color: #666; font-size: 13px; }
        
        .clear { clear: both; }
    </style>
</head>
<body>
    <div class="page-container">
        <div class="header">
            <div class="logo"><%= company.nome %></div>
            <div class="details">
                <%= company.endereco %><br>
                <%= company.documento %><br>
                <br>
                <%= company.telefone %>
            </div>
        </div>
        
        <div class="title-bar">
            Orçamento #<%= quote.id %> - <%= quote.titulo %>
        </div>
        
        <p><strong>Data de Emissão:</strong> <%= new Date(quote.data_criacao).toLocaleDateString('pt-BR') %></p>
        <% if (!(!quote.solicitante_nome || quote.solicitante_nome.length === 0)) { %>
            <p style="margin-top: 5px;">
                <strong>Solicitante:</strong> <%= quote.solicitante_nome %> 
                (CNPJ: <%= quote.solicitante_cnpj %>)
            </p>
        <% } %>
        
        <table>
            <thead>
                <tr>
                    <th>DESCRIÇÃO</th>
                    <th style="width: 50px; text-align: center;">UN</th>
                    <th style="width: 80px; text-align: center;">QTD</th>
                    <th style="width: 120px; text-align: right;">PREÇO UNIT.</th>
                    <th style="width: 120px; text-align: right;">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item) { %>
                <tr>
                    <td>
                    <%= item.descricao %>
                    <% if (item.marca_modelo) { %><br><small style="color: #666;">Marca/Modelo: <%= item.marca_modelo %></small><% } %>
                </td>
                    <td style="text-align: center;"><%= item.unidade ?? 'UN' %></td>
                    <td style="text-align: center;"><%= Number(item.quantidade).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                    <td style="text-align: right;"><%= Number(item.final_price).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                    <td style="text-align: right;"><%= Number(item.total_price).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
        
        <div class="summary">
            <div class="summary-row">
                <span>Subtotal:</span>
                <span>R$ <%= Number(grandTotal).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
            </div>
            <div class="summary-row summary-total">
                <span>Total a Pagar:</span>
                <span>R$ <%= Number(grandTotal).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
            </div>
        </div>
        
        <div class="clear"></div>
        
        <div class="notes">
            <strong>Observações:</strong><br>
            <% if (!(!company.detalhes_adicionais || company.detalhes_adicionais.length === 0)) { %>
                <%- company.detalhes_adicionais %>
            <% } else { %>
                Obrigado pela preferência!
            <% } %>
        </div>
    </div>
</body>
</html>
