<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Orçamento - <%= company.nome %></title>
    <style>
        body {
            font-family: Helvetica, Arial, sans-serif;
            color: #222;
            background: #fff;
            padding: 30px;
        }
        @page { size: A4; margin: 1.5cm; }
        
        .top-bar {
            background: #222;
            color: #fff;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .top-bar h1 {
            margin: 0;
            font-size: 22px;
            letter-spacing: 1px;
        }
        
        .client-box {
            border: 3px solid #222;
            padding: 20px;
            margin: 20px 0;
            display: flex;
            justify-content: space-between;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th {
            background: #222;
            color: #fff;
            text-align: left;
            padding: 10px;
            text-transform: uppercase;
            font-size: 13px;
        }
        td {
            padding: 10px;
            border-bottom: 2px solid #ddd;
        }
        
        .total-box {
            float: right;
            background: #222;
            color: #fff;
            padding: 15px 30px;
            margin-top: 20px;
            font-size: 20px;
            font-weight: bold;
        }
        
        .clear { clear: both; }
        
        .notes {
            margin-top: 40px;
            border-top: 1px dotted #999;
            padding-top: 10px;
            font-size: 12px;
        }
        .rich-text {
            margin-top: 30px;
        }
    </style>
</head>
<body>
    <div class="top-bar">
        <h1><%= company.nome %></h1>
        <div>ORÇAMENTO #<%= quote.id %></div>
    </div>

    <div class="client-box">
        <div>
            <strong>EMISSOR:</strong><br>
            <%= company.nome %><br>
            <%= company.endereco %><br>
            CNPJ: <%= company.documento %>
        </div>
        <div style="text-align:right;">
            <strong>CONTATO:</strong><br>
            <br>
            <%= company.telefone %>
            <% if (!(!quote.solicitante_nome || quote.solicitante_nome.length === 0)) { %>
                <div style="margin-top:10px; padding-top:5px; border-top:1px solid #ddd;">
                    <strong>SOLICITANTE:</strong><br>
                    <%= quote.solicitante_nome %><br>
                    <%= quote.solicitante_cnpj %>
                </div>
            <% } %>
        </div>
    </div>

    <h3>PROPOSTA COMERCIAL: <%= quote.titulo %></h3>
    <p>Data: <%= new Date(quote.data_criacao).toLocaleDateString('pt-BR') %></p>

    <table>
        <thead>
            <tr>
                <th>Descrição do Item</th>
                <th style="width: 50px;">UN</th>
                <th style="width: 80px;">Qtd</th>
                <th style="width: 120px;">V. Unit.</th>
                <th style="width: 120px;">Subtotal</th>
            </tr>
        </thead>
        <tbody>
            <% 
            var grandTotal = 0;
            items.forEach(function(item) { 
                grandTotal += item.total_price;
            %>
            <tr>
                <td><%= item.descricao %></td>
                <td><%= item.unidade ?? 'UN' %></td>
                <td><%= Number(item.quantidade).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                <td>R$ <%= Number(item.final_price).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                <td>R$ <%= Number(item.total_price).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="total-box">
        TOTAL: R$ <%= Number(grandTotal).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
    </div>
    
    <div class="clear"></div>

    <div class="notes">
        <% if (!(!company.detalhes_adicionais || company.detalhes_adicionais.length === 0)) { %>
            <div class="rich-text">
                <%- company.detalhes_adicionais %>
            </div>
        <% } else { %>
            <p>Condições de Pagamento: A combinar.</p>
            <p>Validade da Proposta: 7 dias úteis.</p>
        <% } %>
    </div>
</body>
</html>
