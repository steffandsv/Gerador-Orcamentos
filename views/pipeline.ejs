<%- include('layout_header') %>
<% /* Pipeline Board — Hybrid View v3 */ %>
<link rel="stylesheet" href="/style.css?v=<%= Date.now() %>">

<div class="pipeline-toolbar">
    <div class="pipeline-toolbar-left">
        <h2 class="pipeline-title"><i class="fas fa-columns"></i> Pipeline</h2>
        <div class="pipeline-filters">
            <input type="text" id="filterSearch" class="filter-input" placeholder="Buscar por título...">
            <select id="filterAssignee" class="filter-select">
                <option value="">Todos os responsáveis</option>
                <% users.forEach(function(u) { %>
                    <option value="<%= u.id %>"><%= u.nome_completo || u.username %></option>
                <% }); %>
            </select>
            <select id="filterLabel" class="filter-select">
                <option value="">Todas as etiquetas</option>
            </select>
        </div>
    </div>
    <div class="pipeline-toolbar-right">
        <button class="btn-pipeline btn-labels" onclick="openLabelManager()" title="Gerenciar Etiquetas">
            <i class="fas fa-tags"></i>
        </button>
        <button class="btn-pipeline btn-new" onclick="openNewCardModal()">
            <i class="fas fa-plus"></i> Nova Cotação
        </button>
    </div>
</div>

<!-- ═══════════ PIPELINE BOARD — 3 Active + Summary ═══════════ -->
<div class="pipeline-board" id="pipelineBoard">
    <% var activeStages = ['inbox','cotacao','revisao']; %>
    <% var activeMeta = { inbox: {label:'Inbox',icon:'📩'}, cotacao: {label:'Em Cotação',icon:'⚡'}, revisao: {label:'Revisão',icon:'🔍'} }; %>
    <% activeStages.forEach(function(key) { var meta = activeMeta[key]; %>
    <div class="pipeline-column" data-stage="<%= key %>" id="stage-<%= key %>">
        <div class="column-header">
            <span class="column-icon"><%= meta.icon %></span>
            <span class="column-title"><%= meta.label %></span>
            <span class="column-count" id="count-<%= key %>">0</span>
        </div>
        <div class="column-body" data-stage="<%= key %>"
             ondragover="handleDragOver(event)"
             ondragleave="handleDragLeave(event)"
             ondrop="handleDrop(event, '<%= key %>')">
        </div>
    </div>
    <% }); %>

    <!-- Enviados Summary Card -->
    <div class="pipeline-column enviados-summary-column" id="stage-enviados">
        <div class="column-header">
            <span class="column-icon">✅</span>
            <span class="column-title">Enviados</span>
            <span class="column-count" id="count-enviados">0</span>
        </div>
        <div class="column-body enviados-summary-body enviados-drop-zone"
             ondragover="handleDragOver(event)"
             ondragleave="handleDragLeave(event)"
             ondrop="handleDrop(event, 'enviados')">
            <div class="enviados-drop-message">
                <i class="fas fa-arrow-down" style="font-size:1.4rem;color:var(--accent);margin-bottom:8px;"></i>
                <p><strong>Arraste cards aqui</strong></p>
                <p style="color:#94a3b8;font-size:0.78rem;margin-top:4px;">Ao mover para cá, a cotação será registrada como enviada e aparecerá na tabela abaixo para acompanhamento.</p>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ ENVIADOS TABLE ═══════════ -->
<div class="enviados-section" id="enviadosSection">
    <div class="enviados-header">
        <h3 class="enviados-title">✅ Enviados</h3>
        <div class="enviados-filters">
            <input type="text" id="enviadosSearch" class="filter-input" placeholder="Buscar título ou solicitante...">
            <select id="enviadosOutcome" class="filter-select">
                <option value="">Todos os resultados</option>
                <option value="pending">⏳ Aguardando</option>
                <option value="won">🏆 Vencemos</option>
                <option value="lost">❌ Perdemos</option>
            </select>
            <select id="enviadosAssignee" class="filter-select">
                <option value="">Todos os responsáveis</option>
                <% users.forEach(function(u) { %>
                    <option value="<%= u.id %>"><%= u.nome_completo || u.username %></option>
                <% }); %>
            </select>
        </div>
    </div>
    <div class="enviados-table-wrap">
        <table class="enviados-table" id="enviadosTable">
            <thead>
                <tr>
                    <th class="sortable" data-sort="titulo" onclick="sortEnviados('titulo')">Título <i class="fas fa-sort sort-icon"></i></th>
                    <th>Solicitante</th>
                    <th>Responsável</th>
                    <th>Etiquetas</th>
                    <th class="sortable" data-sort="deadline" onclick="sortEnviados('deadline')">Data Limite <i class="fas fa-sort sort-icon"></i></th>
                    <th class="sortable active-sort" data-sort="updated_at" onclick="sortEnviados('updated_at')">Atualizado <i class="fas fa-sort-down sort-icon"></i></th>
                    <th>Resultado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="enviadosBody">
                <tr class="loading-row"><td colspan="8"><i class="fas fa-spinner fa-spin"></i> Carregando...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="enviados-pagination" id="enviadosPagination"></div>
</div>

<!-- ═══════════ CARD DETAIL MODAL ═══════════ -->
<div class="card-modal-overlay" id="cardModal" style="display:none;">
    <div class="card-modal">
        <div class="card-modal-header">
            <h3 class="card-modal-title" id="modalTitle">—</h3>
            <button class="card-modal-close" onclick="closeCardModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-modal-body">
            <div class="card-modal-main">
                <!-- Tab Navigation -->
                <div class="card-tabs">
                    <button class="card-tab active" data-tab="desc" onclick="switchCardTab('desc')">
                        <i class="fas fa-align-left"></i> Descrição
                    </button>
                    <button class="card-tab" data-tab="stats" onclick="switchCardTab('stats')">
                        <i class="fas fa-chart-bar"></i> Estatísticas
                    </button>
                    <button class="card-tab" data-tab="comments" onclick="switchCardTab('comments')">
                        <i class="fas fa-comments"></i> Comentários <span id="commentCountBadge" class="tab-badge" style="display:none;"></span>
                    </button>
                </div>

                <!-- Tab: Descrição -->
                <div class="card-tab-content active" id="tabDesc">
                    <div class="modal-section">
                        <div class="section-header">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span class="desc-save-status" id="descSaveStatus"></span>
                            </div>
                            <button class="desc-edit-btn" id="btnEditDesc" onclick="setDescTab('write')" title="Editar descrição">
                                <i class="fas fa-pencil-alt"></i>
                            </button>
                        </div>
                        <div id="descWritePane" style="display:none;">
                            <textarea id="modalDescription" class="modal-textarea"
                                placeholder="Adicione uma descrição detalhada (aceita Markdown)..."
                                oninput="onDescriptionInput()"></textarea>
                            <button class="desc-done-btn" onclick="setDescTab('preview')">
                                <i class="fas fa-check"></i> Concluído
                            </button>
                        </div>
                        <div id="descPreviewPane" class="md-preview">
                            <div id="descPreviewContent" class="md-content"></div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Estatísticas -->
                <div class="card-tab-content" id="tabStats" style="display:none;">
                    <div class="stats-grid" id="cardStatsGrid">
                        <div class="stat-card">
                            <div class="stat-label">Itens</div>
                            <div class="stat-value" id="statItemCount">—</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Total Compra</div>
                            <div class="stat-value stat-money" id="statTotalCompra">—</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Total Venda</div>
                            <div class="stat-value stat-money" id="statTotalVenda">—</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Lucro Projetado</div>
                            <div class="stat-value stat-profit" id="statLucro">—</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">% Lucro</div>
                            <div class="stat-value" id="statLucroPercent">—</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Comissão Projetada</div>
                            <div class="stat-value stat-commission" id="statComissao">—</div>
                        </div>
                    </div>
                    <p class="stats-note" id="statsNote" style="display:none;"><i class="fas fa-info-circle"></i> Adicione itens ao orçamento para ver as estatísticas.</p>
                </div>

                <!-- Tab: Comentários -->
                <div class="card-tab-content" id="tabComments" style="display:none;">
                    <div class="modal-section">
                        <div id="commentsList" class="comments-list"></div>
                        <div class="comment-composer">
                            <textarea id="commentInput" class="comment-input"
                                placeholder="Escreva um comentário... Use @nome para mencionar alguém"
                                rows="2" onkeydown="handleCommentKey(event)"></textarea>
                            <div class="mention-dropdown" id="mentionDropdown" style="display:none;"></div>
                            <button class="btn-pipeline btn-sm" onclick="submitComment()">
                                <i class="fas fa-paper-plane"></i> Enviar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-modal-sidebar">
                <!-- Assignee -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-user"></i> Responsável</label>
                    <select id="modalAssignee" class="sidebar-select" onchange="assignUser()">
                        <option value="">Ninguém</option>
                        <% users.forEach(function(u) { %>
                            <option value="<%= u.id %>"><%= u.nome_completo || u.username %></option>
                        <% }); %>
                    </select>
                </div>

                <!-- Labels (inline type-to-add) -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-tags"></i> Etiquetas</label>
                    <div id="modalLabels" class="modal-labels-list"></div>
                    <div class="label-inline-add">
                        <input type="text" id="labelInlineInput" class="sidebar-input sidebar-input-sm"
                            placeholder="Adicionar etiqueta..."
                            onkeydown="handleLabelInputKey(event)"
                            oninput="showLabelSuggestions()">
                        <div class="label-suggestions" id="labelSuggestions" style="display:none;"></div>
                    </div>
                </div>

                <!-- Deadline -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-clock"></i> Data Limite</label>
                    <input type="datetime-local" id="modalDeadline" class="sidebar-input" onchange="saveDeadline()">
                </div>

                <!-- Outcome (for 'enviados') -->
                <div class="sidebar-section" id="outcomeSection" style="display:none;">
                    <label class="sidebar-label"><i class="fas fa-trophy"></i> Resultado</label>
                    <select id="modalOutcome" class="sidebar-select outcome-select" onchange="setOutcome(this.value)">
                        <option value="">⏳ Aguardando</option>
                        <option value="won">🏆 Vencemos</option>
                        <option value="lost">❌ Perdemos</option>
                        <option value="help">🤝 Para Ajudar</option>
                    </select>
                </div>

                <!-- Delivery Method -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-paper-plane"></i> Envio</label>
                    <div class="delivery-toggle" id="deliveryToggle">
                        <button class="delivery-opt" data-type="email" onclick="setDeliveryType('email')">
                            <i class="fas fa-envelope"></i> Email
                        </button>
                        <button class="delivery-opt" data-type="link" onclick="setDeliveryType('link')">
                            <i class="fas fa-globe"></i> Sistema
                        </button>
                    </div>
                    <input type="text" id="modalDeliveryTarget" class="sidebar-input sidebar-input-sm"
                        placeholder="Email ou URL do sistema..."
                        onchange="saveDeliveryTarget()" style="margin-top:6px;display:none;">
                </div>

                <!-- Links -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-link"></i> Links</label>
                    <div id="modalLinksList" class="links-list"></div>
                    <div class="link-add-row">
                        <input type="text" id="linkLabelInput" class="sidebar-input sidebar-input-sm" placeholder="Rótulo" style="flex:1">
                        <input type="text" id="linkUrlInput" class="sidebar-input sidebar-input-sm" placeholder="https://..." style="flex:2">
                        <button class="btn-icon btn-add-link" onclick="addLink()" title="Adicionar"><i class="fas fa-plus"></i></button>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="sidebar-section">
                    <label class="sidebar-label"><i class="fas fa-bolt"></i> Ações</label>
                    <a id="btnSendAction" href="#" class="sidebar-action" onclick="handleSendAction(); return false;" style="display:none;">
                        <i class="fas fa-paper-plane" id="sendActionIcon"></i> <span id="sendActionText">Enviar</span>
                    </a>
                    <a id="btnEditQuote" href="#" class="sidebar-action" onclick="openQuoteEditor(); return false;">
                        <i class="fas fa-edit"></i> Editar Orçamento
                    </a>
                    <a href="#" class="sidebar-action" onclick="openCsvImportOverlay(); return false;">
                        <i class="fas fa-file-csv"></i> Importar CSV
                    </a>
                    <a id="btnPrintQuote" href="#" class="sidebar-action" onclick="generateQuotesFromModal(); return false;">
                        <i class="fas fa-print"></i> Gerar PDFs
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ QUOTE EDITOR OVERLAY ═══════════ -->
<div class="editor-overlay" id="quoteEditorOverlay" style="display:none;">
    <div class="editor-overlay-header">
        <h3><i class="fas fa-edit"></i> Editar Orçamento</h3>
        <button class="card-modal-close" onclick="closeQuoteEditor()"><i class="fas fa-times"></i></button>
    </div>
    <iframe id="quoteEditorIframe" class="editor-overlay-iframe"></iframe>
</div>

<!-- ═══════════ NEW CARD MODAL ═══════════ -->
<div class="card-modal-overlay" id="newCardModal" style="display:none;">
    <div class="card-modal" style="max-width:600px;">
        <div class="card-modal-header">
            <h3 class="card-modal-title"><i class="fas fa-plus-circle" style="color:var(--accent);margin-right:6px;"></i> Nova Cotação</h3>
            <button class="card-modal-close" onclick="closeNewCardModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-modal-body" style="flex-direction:column; padding:20px 24px;">
            <div class="modal-section">
                <label class="sidebar-label"><i class="fas fa-heading"></i> Título *</label>
                <input type="text" id="newCardTitle" class="sidebar-input" placeholder="Ex: Pregão 042/2026 — Material de Limpeza" autofocus>
            </div>
            <div class="modal-section" style="display:flex; gap:16px;">
                <div style="flex:1;">
                    <label class="sidebar-label"><i class="fas fa-user-tie"></i> Solicitante</label>
                    <input type="text" id="newCardSolicitante" class="sidebar-input" placeholder="Nome do solicitante ou órgão">
                </div>
                <div style="flex:1;">
                    <label class="sidebar-label"><i class="fas fa-id-card"></i> CNPJ</label>
                    <input type="text" id="newCardCnpj" class="sidebar-input" placeholder="00.000.000/0000-00">
                </div>
            </div>
            <div class="modal-section">
                <label class="sidebar-label"><i class="fas fa-align-left"></i> Descrição</label>
                <textarea id="newCardDescription" class="modal-textarea" rows="3"
                    placeholder="Descrição detalhada da cotação..."></textarea>
            </div>
            <div class="modal-section" style="display:flex; gap:16px;">
                <div style="flex:1;">
                    <label class="sidebar-label"><i class="fas fa-user"></i> Responsável</label>
                    <select id="newCardAssignee" class="sidebar-select">
                        <option value="">Ninguém</option>
                        <% users.forEach(function(u) { %>
                            <option value="<%= u.id %>"><%= u.nome_completo || u.username %></option>
                        <% }); %>
                    </select>
                </div>
                <div style="flex:1;">
                    <label class="sidebar-label"><i class="fas fa-clock"></i> Data Limite</label>
                    <input type="datetime-local" id="newCardDeadline" class="sidebar-input">
                </div>
            </div>
            <div class="modal-section">
                <label class="sidebar-label"><i class="fas fa-paper-plane"></i> Tipo de Envio</label>
                <div class="delivery-toggle" id="newCardDeliveryToggle">
                    <button class="delivery-opt" data-type="email" onclick="setNewCardDeliveryType('email')">
                        <i class="fas fa-envelope"></i> Email
                    </button>
                    <button class="delivery-opt" data-type="link" onclick="setNewCardDeliveryType('link')">
                        <i class="fas fa-globe"></i> Sistema
                    </button>
                </div>
                <input type="text" id="newCardDeliveryTarget" class="sidebar-input sidebar-input-sm"
                    placeholder="Email ou URL do sistema..." style="margin-top:6px;display:none;">
            </div>
            <div class="modal-section">
                <label class="sidebar-label"><i class="fas fa-file-csv"></i> Itens</label>
                <button class="btn-pipeline btn-import-items" id="newCardImportBtn" onclick="openNewCardCsvImport()">
                    <i class="fas fa-upload"></i> <span id="newCardImportLabel">Importar Itens (CSV)</span>
                </button>
            </div>
            <div class="modal-section">
                <label class="sidebar-label"><i class="fas fa-tags"></i> Etiquetas</label>
                <div id="newCardLabels" class="modal-labels-list" style="margin-bottom:6px;"></div>
                <div class="label-inline-add">
                    <input type="text" id="newCardLabelInput" class="sidebar-input sidebar-input-sm"
                        placeholder="Adicionar etiqueta..."
                        onkeydown="handleNewCardLabelKey(event)"
                        oninput="showNewCardLabelSuggestions()">
                    <div class="label-suggestions" id="newCardLabelSuggestions" style="display:none;"></div>
                </div>
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:8px;">
                <button class="btn-pipeline btn-labels" onclick="closeNewCardModal()">Cancelar</button>
                <button class="btn-pipeline btn-new" onclick="submitNewCard()">
                    <i class="fas fa-plus"></i> Criar Cotação
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ CSV IMPORT OVERLAY ═══════════ -->
<div class="card-modal-overlay" id="csvOverlay" style="display:none;">
    <div class="card-modal" style="max-width:550px;">
        <div class="card-modal-header">
            <h3 class="card-modal-title"><i class="fas fa-file-csv" style="color:var(--accent);margin-right:6px;"></i> Importar Itens CSV</h3>
            <button class="card-modal-close" onclick="closeCsvOverlay()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-modal-body" style="flex-direction:column; padding:20px 24px;">
            <p style="font-size:0.85rem; color:#64748b; margin:0 0 12px;">Cole os dados CSV abaixo. Formato: <code>Código;Descrição;Quantidade;Valor</code> (uma linha por item).</p>
            <textarea id="csvOverlayInput" class="modal-textarea" rows="8"
                placeholder="Material de Limpeza;100;5.50&#10;Papel A4;50;22.90&#10;..."></textarea>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:12px;">
                <span class="csv-status" id="csvOverlayStatus"></span>
                <button class="btn-pipeline btn-new" onclick="importCsvFromOverlay()">
                    <i class="fas fa-upload"></i> Importar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════ LABEL MANAGER MODAL ═══════════ -->
<div class="card-modal-overlay" id="labelManagerModal" style="display:none;">
    <div class="card-modal label-manager-modal">
        <div class="card-modal-header">
            <h3 class="card-modal-title"><i class="fas fa-tags"></i> Gerenciar Etiquetas</h3>
            <button class="card-modal-close" onclick="closeLabelManager()"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-modal-body" style="flex-direction:column;">
            <div class="label-create-row">
                <input type="text" id="newLabelName" class="filter-input" placeholder="Nome da etiqueta">
                <input type="color" id="newLabelColor" class="label-color-input" value="#3b82f6">
                <button class="btn-pipeline btn-sm" onclick="createLabel()"><i class="fas fa-plus"></i> Criar</button>
            </div>
            <div id="labelManagerList" class="label-manager-list"></div>
        </div>
    </div>
</div>

<script>
    window.__PIPELINE_USERS__ = <%- JSON.stringify(users) %>;
    window.__CURRENT_USER__ = <%- JSON.stringify(typeof currentUser !== 'undefined' ? currentUser : {}) %>;
</script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="/js/pipeline.js?v=<%= Date.now() %>" defer></script>
<%- include('layout_footer') %>
