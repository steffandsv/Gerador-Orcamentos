<%- include('layout_header') %>
<h2>Empresas Cadastradas</h2>
<div style="margin-bottom: 15px;">
    <a href="/empresas/form" class="btn">Nova Empresa</a>
</div>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Nome</th>
            <th>Documento</th>
            <th>Email</th>
            <th>Docs</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        <% if ((!empresas || empresas.length === 0)) { %>
        <tr>
            <td colspan="6" style="text-align:center;">Nenhuma empresa cadastrada.</td>
        </tr>
        <% } else { %>
            <% empresas.forEach(function(emp) { %>
            <tr>
                <td><%= emp.id %></td>
                <td><%= emp.nome %></td>
                <td><%= emp.documento %></td>
                <td><%= emp.email %></td>
                <td style="text-align:center;">
                    <% if (emp.doc_original_name) { %>
                        <span title="<%= emp.doc_original_name %>" style="cursor:help; font-size:1.2em;">
                            <%= emp.doc_original_name.endsWith('.pdf') ? '📄' : '📦' %>
                        </span>
                    <% } else { %>
                        <span style="color:#ccc;" title="Sem documentação">—</span>
                    <% } %>
                </td>
                <td>
                    <a href="/empresas/form?id=<%= emp.id %>" class="btn btn-small">Editar</a>
                    <form action="/empresas/delete" method="POST" style="display:inline;" onsubmit="return confirm('Tem certeza?');">
                        <input type="hidden" name="id" value="<%= emp.id %>">
                        <button type="submit" class="btn btn-small btn-danger">Excluir</button>
                    </form>
                </td>
            </tr>
            <% }); %>
        <% } %>
    </tbody>
</table>
<%- include('layout_footer') %>
